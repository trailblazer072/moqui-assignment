<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">
    <entity entity-name="MoquiTraining" package="tutorial">
        <field name="trainingId" type="id" is-pk="true"/>
        <field name="trainingName" type="text-medium"/>
        <field name="trainingDate" type="date"/>
        <field name="trainingPrice" type="currency-amount"/>
        <field name="trainingDays" type="number-integer"/>
    </entity>
    <entity entity-name="MoquiTraining2" package="tutorial">
        <field name="trainingId" type="id" is-pk="true"/>
        <field name="trainingName" type="text-medium"/>
        <field name="trainingDate" type="date"/>
    </entity>
    <entity entity-name="Party" package="party">
        <field name="partyId" type="id" is-pk="true"/>
        <field name="partyTypeEnumId" type="id"/>
        <field name="createdDate" type="date-time"/>
        <relationship type="one" related="moqui.basic.Enumeration" short-alias="partyType">
            <key-map field-name="partyTypeEnumId" related="enumId"/>
        </relationship>
    </entity>

    <!--person Entity-->
    <entity entity-name="Person" package="party">
        <field name="partyId" type="id" is-pk="true"/>
        <field name="firstName" type="text-medium"/>
        <field name="lastName" type="text-medium"/>
        <field name="dateOfBirth" type="date"/>
        <relationship type="one" related="Party">
            <key-map field-name="partyId"/>
        </relationship>
    </entity>

    <!--partyGroup Entity-->
    <entity entity-name="PartyGroup" package="party">
        <field name="partyId" type="id" is-pk="true"/>
        <field name="groupName" type="text-medium"/>
        <field name="description" type="text-medium"/>
        <relationship type="one" related="Party">
            <key-map field-name="partyId"/>
        </relationship>
    </entity>

    <!--contactMech-->
    <entity entity-name="ContactMech" package="party">
        <field name="contactMechId" type="id" is-pk="true"/>
        <field name="contactMechTypeId" type="id"/>
        <field name="infoString" type="text-long"/>
        <field name="createdDate" type="date-time"/>
        <relationship type="one" related="moqui.basic.Enumeration" short-alias="contactMechType">
            <key-map field-name="contactMechTypeId" related="enumId"/>
        </relationship>
    </entity>

    <!-- PartyContactMech Entity -->
    <entity entity-name="PartyContactMech" package="party">
        <field name="partyId" type="id" is-pk="true"/>
        <field name="contactMechId" type="id" is-pk="true"/>
        <field name="fromDate" type="date-time" is-pk="true"/>
        <field name="thruDate" type="date-time" is-pk="true"/>
        <relationship type="one" related="Party">
            <key-map field-name="partyId"/>
        </relationship>
        <relationship type="one" related="ContactMech">
            <key-map field-name="contactMechId"/>
        </relationship>
    </entity>
</entities>